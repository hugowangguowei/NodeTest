{
  "$id": "standardKnowledge",
  "type": "object",
  "required": [
    "standard_knowledge_version",
    "knowledge_id",
    "domain_scope",
    "documents",
    "document_slices",
    "entities",
    "behaviors",
    "events",
    "relationships",
    "business_flows",
    "rules",
    "source_registry",
    "uncertainties",
    "validation"
  ],
  "properties": {
    "standard_knowledge_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "knowledge_id": {
      "type": "string",
      "minLength": 1
    },
    "domain_scope": {
      "type": "string",
      "enum": ["cross-domain", "single-domain", "unknown"]
    },
    "documents": {
      "type": "array",
      "items": { "$ref": "#/$defs/document" }
    },
    "document_slices": {
      "type": "array",
      "items": { "$ref": "#/$defs/documentSlice" }
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" }
    },
    "behaviors": {
      "type": "array",
      "items": { "$ref": "#/$defs/behavior" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationship" }
    },
    "business_flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/businessFlow" }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    },
    "source_registry": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRecord" }
    },
    "uncertainties": {
      "type": "array",
      "items": { "$ref": "#/$defs/uncertainty" }
    },
    "validation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "warn", "fail"]
        },
        "message": { "type": "string" },
        "checked_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
        },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "document": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "source_type": { "type": "string" },
        "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" }
      },
      "additionalProperties": true
    },
    "documentSlice": {
      "type": "object",
      "required": ["id", "document_ref"],
      "properties": {
        "id": { "type": "string" },
        "document_ref": { "type": "string" },
        "content": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": true
    },
    "entity": {
      "type": "object",
      "required": [
        "id",
        "name",
        "entity_type",
        "aliases",
        "description",
        "attributes",
        "source_refs",
        "uncertainties"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "entity_type": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" },
        "attributes": { "type": "object" },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uncertainties": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "behavior": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "relationship": {
      "type": "object",
      "required": ["id", "relationship_type", "from_ref", "to_ref"],
      "properties": {
        "id": { "type": "string" },
        "relationship_type": { "type": "string" },
        "from_ref": { "type": "string" },
        "to_ref": { "type": "string" }
      },
      "additionalProperties": true
    },
    "businessFlow": {
      "type": "object",
      "required": [
        "id",
        "name",
        "flow_type",
        "goal",
        "node_refs",
        "entry_rule_refs",
        "exit_rule_refs",
        "entity_refs",
        "event_refs",
        "rule_refs",
        "source_refs",
        "uncertainties"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "flow_type": { "type": "string" },
        "goal": { "type": "string" },
        "node_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entry_rule_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exit_rule_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entity_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "event_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rule_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uncertainties": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "rule": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sourceRecord": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "source_type": { "type": "string" },
        "source_uri": { "type": "string" }
      },
      "additionalProperties": true
    },
    "uncertainty": {
      "type": "object",
      "required": ["id", "message"],
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
